# ─── Configuración del servidor ───
PORT=3000

# ─── Conexión a MySQL / MariaDB ───
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_seguro
DB_NAME=scae

# ─── Seguridad ───
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria
JWT_EXPIRES_IN=7d

# ─── CORS ───
# Lista separada por comas con los orígenes permitidos.
# Usa * en desarrollo, pero pon dominios reales en producción.
CORS_ORIGIN=*
